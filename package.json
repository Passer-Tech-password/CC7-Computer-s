{
  "name": "cc7-computers",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.2.0",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "node node_modules/next/dist/bin/next dev --turbopack",
    "build": "node -e \"const fs=require('fs'); fs.rmSync('out',{recursive:true,force:true}); fs.mkdirSync('.next',{recursive:true});\" && node node_modules/next/dist/bin/next build",
    "start": "node node_modules/next/dist/bin/next start",
    "lint": "node node_modules/next/dist/bin/next lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@firebase/app": "0.10.13",
    "@firebase/component": "0.6.9",
    "@heroicons/react": "^2.2.0",
    "firebase": "^10.14.1",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^1.7.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^20.11.30",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.0",
    "postcss": "^8.5.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2"
  }
}
